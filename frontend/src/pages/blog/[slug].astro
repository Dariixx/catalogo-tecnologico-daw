---
// src/pages/blog/[slug].astro

import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import BlocksRenderer from "../../components/BlocksRenderer.astro";
import { getReadingTimeMinutes } from "../../lib/readingTime";
import { strapiFetch } from "../../lib/strapi.js";

function unwrapEntity(entity) {
  if (!entity) return null;
  return entity.attributes ? { id: entity.id, ...entity.attributes } : entity;
}
function unwrapCollection(json) {
  const data = json?.data;
  if (Array.isArray(data)) return data.map(unwrapEntity).filter(Boolean);
  if (data) return [unwrapEntity(data)].filter(Boolean);
  return [];
}

const STRAPI_URL =
  import.meta.env.STRAPI_URL ||
  process.env.STRAPI_URL ||
  "https://api.zetagadget.es";

const toAbs = (maybeUrl) => {
  if (!maybeUrl) return null;
  if (/^https?:\/\//i.test(maybeUrl)) return maybeUrl;
  try {
    return new URL(maybeUrl, STRAPI_URL).toString();
  } catch {
    return null;
  }
};

// ✅ PRIORIZA ORIGINAL (m.url) -> luego formatos
const pickMediaUrl = (media) => {
  const m =
    media?.data?.attributes ??
    media?.data ??
    media?.attributes ??
    media ??
    null;

  if (!m) return null;

  const rel =
    m?.url ??
    m?.formats?.large?.url ??
    m?.formats?.medium?.url ??
    m?.formats?.small?.url ??
    m?.formats?.thumbnail?.url ??
    null;

  return rel ? toAbs(rel) : null;
};

// ✅ Quita thumbnail_/small_/medium_/large_ en <img src="...">
function fixRichTextImages(html) {
  if (!html) return html;

  // 1) convierte src="/uploads/..." a src="https://api.../uploads/..."
  let out = html.replaceAll(
    'src="/uploads/',
    `src="${STRAPI_URL.replace(/\/$/, "")}/uploads/`
  );

  // 2) si viene /uploads/thumbnail_xxx -> /uploads/xxx (original)
  out = out.replace(/(\/uploads\/)(thumbnail_|small_|medium_|large_)/g, "$1");

  return out;
}

export async function getStaticPaths() {
  const base = import.meta.env.STRAPI_URL;
  if (!base) throw new Error("Falta STRAPI_URL en el entorno de build");

  const url = `${base}/api/articles?fields[0]=slug&pagination[pageSize]=1000`;
  const res = await fetch(url);

  if (!res.ok) {
    const text = await res.text().catch(() => "");
    throw new Error(
      `Strapi no respondió (${res.status}) al generar static paths. ${text.slice(0, 200)}`
    );
  }

  const json = await res.json();
  const items = json?.data ?? [];
  return items.filter((x) => x?.slug).map((x) => ({ params: { slug: x.slug } }));
}

const { slug } = Astro.params;

const articleRes = await strapiFetch(
  `/articles?filters[slug][$eq]=${encodeURIComponent(slug)}` +
  `&populate[0]=author.avatar` +
  `&populate[1]=cover` +
  `&populate[2]=category` +
  `&populate[3]=blocks.file` +
  `&populate[4]=blocks.files` +
  `&populate[5]=blocks.image` +
  `&populate[6]=blocks.media`
);
const articles = unwrapCollection(articleRes);
const a = articles[0];
if (!a) throw new Error(`Artículo no encontrado para slug: ${slug}`);

const moreRes = await strapiFetch(
  `/articles?filters[slug][$ne]=${encodeURIComponent(slug)}&populate[author][populate]=avatar&populate[cover]=true&pagination[pageSize]=3&sort=publishedAt:desc`
);
const moreRaw = unwrapCollection(moreRes);
const more = moreRaw.slice(0, 3);

// ✅ author definido antes de usarlo
const author =
  a.author?.data?.attributes ??
  a.author?.data ??
  a.author ??
  null;

const coverUrl = pickMediaUrl(a.cover);
const authorAvatarUrl = pickMediaUrl(author?.avatar);

const readingMinutes = getReadingTimeMinutes({ content: a.content, blocks: a.blocks });

const publishedAtRaw = a.publishedAt ? new Date(a.publishedAt) : null;
const publishedAt = publishedAtRaw
  ? new Intl.DateTimeFormat("es-ES", {
      day: "numeric",
      month: "long",
      year: "numeric",
    }).format(publishedAtRaw)
  : null;

const description = a.description ?? a.excerpt ?? a.title;

// ✅ si viene HTML, lo “arreglamos” para no usar thumbnails
const contentHtml = a?.content ? fixRichTextImages(a.content) : null;
---

<BaseLayout
  title={`${a.title} — Blog ZetaGadget`}
  description={description}
  image={coverUrl ?? undefined}
  canonical={`/blog/${slug}/`}
>
  <main class="container-page py-10">
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol
        class="flex flex-wrap items-center gap-1.5 text-sm rounded-2xl px-4 py-3"
        style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);"
      >
        <li><a href="/" style="color: rgba(229,229,229,0.55);">Inicio</a></li>
        <li style="color: rgba(229,229,229,0.25);">›</li>
        <li><a href="/blog" style="color: rgba(229,229,229,0.55);">Blog</a></li>
        <li style="color: rgba(229,229,229,0.25);">›</li>
        <li
          class="font-semibold truncate max-w-[220px] sm:max-w-md"
          style="color: rgba(229,229,229,0.85);"
          aria-current="page"
        >
          {a.title}
        </li>
      </ol>
    </nav>

    <header class="mb-10">
      {coverUrl && (
        <div
          class="overflow-hidden rounded-3xl mb-8"
          style="background:#151a22; border: 1px solid rgba(255,255,255,0.08);"
        >
          <img
            src={coverUrl}
            alt={a.title}
            class="w-full object-cover"
            style="max-height: 520px;"
            loading="eager"
            decoding="async"
          />
        </div>
      )}

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight" style="color:#e5e5e5;">
        {a.title}
      </h1>

      {(a.description ?? a.excerpt) && (
        <p class="mt-4 text-base sm:text-lg leading-relaxed max-w-3xl" style="color: rgba(229,229,229,0.65);">
          {a.description ?? a.excerpt}
        </p>
      )}
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-6 items-start">
      <article
        class="rounded-3xl px-6 sm:px-8 py-8"
        style="background:#151a22; border: 1px solid rgba(255,255,255,0.08);"
      >
        <div
          class="flex flex-wrap items-center gap-x-5 gap-y-2 pb-6 mb-6"
          style="border-bottom: 1px solid rgba(255,255,255,0.08);"
        >
          {(author?.name ?? a.authorName) && (
            <span class="flex items-center gap-2.5 text-sm" style="color: rgba(229,229,229,0.70);">
              {authorAvatarUrl ? (
                <img
                  src={authorAvatarUrl}
                  alt={author?.name ?? a.authorName}
                  class="w-8 h-8 rounded-full object-cover"
                  style="border: 1px solid rgba(255,255,255,0.10);"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <span
                  class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-extrabold"
                  style="background: rgba(30,136,229,0.15); color: #3aa0ff; border: 1px solid rgba(30,136,229,0.25);"
                >
                  {(author?.name ?? a.authorName).charAt(0).toUpperCase()}
                </span>
              )}
              {author?.name ?? a.authorName}
            </span>
          )}

          {publishedAt && (
            <span class="flex items-center gap-1.5 text-sm" style="color: rgba(229,229,229,0.45);">
              {publishedAt}
            </span>
          )}

          {!!readingMinutes && (
            <span class="flex items-center gap-1.5 text-sm" style="color: rgba(229,229,229,0.45);">
              {readingMinutes} min lectura
            </span>
          )}
        </div>

        {contentHtml ? (
          <div class="article-content" set:html={contentHtml} />
        ) : (
          <div class="article-content">
            <BlocksRenderer blocks={a.blocks ?? []} />
          </div>
        )}
      </article>

      <aside class="lg:sticky lg:top-24 space-y-4">
        <div
          class="rounded-3xl p-6"
          style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);"
        >
          <p class="text-xs font-semibold uppercase tracking-widest" style="color:#1e88e5;">Acciones</p>

          <div class="mt-4 grid gap-3">
            <button
              type="button"
              id="copyLinkBtn"
              class="w-full rounded-xl px-4 py-3 text-sm font-semibold"
              style="background: rgba(30,136,229,0.12); color:#3aa0ff; border:1px solid rgba(30,136,229,0.25);"
            >
              Copiar enlace
            </button>

            <a
              href="/blog"
              class="w-full inline-flex items-center justify-center rounded-xl px-4 py-3 text-sm font-semibold"
              style="background: rgba(255,255,255,0.06); color: rgba(229,229,229,0.85); border:1px solid rgba(255,255,255,0.10);"
            >
              Volver al blog
            </a>
          </div>

          <p id="copyMsg" class="mt-3 text-xs hidden" style="color: rgba(229,229,229,0.55);"></p>
        </div>

        <div class="rounded-3xl p-6" style="background:#151a22; border: 1px solid rgba(255,255,255,0.08);">
          <p class="text-xs font-semibold uppercase tracking-widest" style="color:#1e88e5;">Resumen</p>
          <div class="mt-3 text-sm leading-relaxed" style="color: rgba(229,229,229,0.60);">
            {description}
          </div>
        </div>
      </aside>
    </div>

    {more.length > 0 && (
      <section class="mt-14">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {more.map((m: any) => {
            const mauthor =
              m.author?.data?.attributes ??
              m.author?.data ??
              m.author ??
              null;

            const mCoverAbs = pickMediaUrl(m.cover);

            return (
              <ArticleCard
                article={{
                  title: m.title,
                  slug: m.slug,
                  description: m.description ?? m.excerpt,
                  coverUrl: mCoverAbs,
                  authorName: mauthor?.name ?? m.authorName ?? null,
                  publishedAt: m.publishedAt,
                  readingTime: getReadingTimeMinutes({ content: m.content, blocks: m.blocks }),
                }}
              />
            );
          })}
        </div>
      </section>
    )}
  </main>

  <script type="module">
    const btn = document.getElementById("copyLinkBtn");
    const msg = document.getElementById("copyMsg");

    btn?.addEventListener("click", async () => {
      const url = window.location.href;
      try {
        await navigator.clipboard.writeText(url);
        msg.classList.remove("hidden");
        msg.textContent = "Enlace copiado ✅";
      } catch {
        msg.classList.remove("hidden");
        msg.textContent = "No se pudo copiar. Copia manual: " + url;
      }
    });
  </script>

  <style is:global>
    /* ══════════════════════════════════════════════
       ARTICLE CONTENT — estilos de blog legibles
       ══════════════════════════════════════════════ */

    .article-content {
      font-size: 1.05rem;
      line-height: 1.9;
      color: rgba(229, 229, 229, 0.82);
      word-break: break-word;
    }

    /* Espaciado entre bloques */
    .article-content > * + * { margin-top: 0.25rem; }

    /* ── Párrafos ── */
    .article-content p {
      margin-bottom: 1.4rem;
      font-size: 1.05rem;
      line-height: 1.9;
      color: rgba(229, 229, 229, 0.80);
    }

    /* ── Headings ── */
    .article-content h2 {
      font-size: clamp(1.4rem, 2.5vw, 1.85rem);
      font-weight: 800;
      color: #f0f0f0;
      margin-top: 2.8rem;
      margin-bottom: 1rem;
      line-height: 1.25;
      letter-spacing: -0.02em;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .article-content h3 {
      font-size: clamp(1.15rem, 2vw, 1.4rem);
      font-weight: 700;
      color: #e5e5e5;
      margin-top: 2.2rem;
      margin-bottom: 0.75rem;
      line-height: 1.3;
    }
    .article-content h4 {
      font-size: 1.1rem;
      font-weight: 700;
      color: #e5e5e5;
      margin-top: 1.8rem;
      margin-bottom: 0.6rem;
    }

    /* ── Links ── */
    .article-content a {
      color: #60a5fa;
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-thickness: 1px;
      transition: color 0.15s;
    }
    .article-content a:hover { color: #93c5fd; }

    /* ── Listas ── */
    .article-content ul,
    .article-content ol {
      padding-left: 1.5rem;
      margin-top: 0.5rem;
      margin-bottom: 1.4rem;
      color: rgba(229, 229, 229, 0.78);
    }
    .article-content ul { list-style: disc; }
    .article-content ol { list-style: decimal; }
    .article-content li {
      margin: 0.4rem 0;
      line-height: 1.75;
      padding-left: 0.25rem;
    }
    .article-content li::marker { color: #3b82f6; }

    /* ── Blockquote ── */
    .article-content blockquote {
      margin: 2rem 0;
      padding: 1.1rem 1.4rem;
      border-left: 3px solid #3b82f6;
      background: rgba(59, 130, 246, 0.06);
      border-radius: 0 16px 16px 0;
      color: rgba(229, 229, 229, 0.82);
      font-style: italic;
      font-size: 1.08rem;
      line-height: 1.75;
    }
    .article-content blockquote cite {
      display: block;
      margin-top: 0.6rem;
      font-size: 0.88rem;
      font-style: normal;
      font-weight: 600;
      color: #60a5fa;
    }

    /* ── Código inline ── */
    .article-content code {
      background: rgba(59, 130, 246, 0.10);
      color: #93c5fd;
      padding: 0.18rem 0.5rem;
      border-radius: 6px;
      font-family: ui-monospace, "Fira Code", "Cascadia Code", SFMono-Regular, Menlo, monospace;
      font-size: 0.9em;
    }

    /* ── Bloque de código ── */
    .article-content pre {
      margin: 2rem 0;
      padding: 1.25rem 1.4rem;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,0.08);
      background: #0d1117;
      overflow-x: auto;
      font-size: 0.9rem;
      line-height: 1.65;
      position: relative;
    }
    .article-content pre::before {
      content: attr(data-lang);
      position: absolute;
      top: 0.6rem;
      right: 0.9rem;
      font-size: 0.72rem;
      font-weight: 600;
      color: rgba(255,255,255,0.3);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-family: inherit;
    }
    .article-content pre code {
      background: transparent;
      padding: 0;
      color: rgba(229, 229, 229, 0.88);
      font-size: inherit;
    }

    /* ── Imágenes ── */
    .article-content img {
      display: block;
      max-width: 100%;
      height: auto;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,0.08);
      margin: 1.8rem auto;
    }
    .article-content figure {
      margin: 2rem 0;
    }
    .article-content figcaption {
      margin-top: 0.5rem;
      text-align: center;
      font-size: 0.85rem;
      color: rgba(229,229,229,0.45);
      font-style: italic;
    }

    /* ── HR ── */
    .article-content hr {
      border: none;
      border-top: 1px solid rgba(255,255,255,0.08);
      margin: 2.5rem 0;
    }

    /* ── Slider ── */
    .article-content .scrollbar-thin::-webkit-scrollbar { height: 4px; }
    .article-content .scrollbar-thin::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 99px; }

    /* ── Strong / em ── */
    .article-content strong { color: #f0f0f0; font-weight: 700; }
    .article-content em { font-style: italic; color: rgba(229,229,229,0.90); }
  </style>
</BaseLayout>