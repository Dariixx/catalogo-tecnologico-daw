---
// src/pages/blog/index.astro
import { getReadingTimeMinutes } from "../../lib/readingTime";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import Pagination from "../../components/Pagination.astro";

const STRAPI_URL =
  import.meta.env.STRAPI_URL ||
  process.env.STRAPI_URL ||
  "https://api.zetagadget.es";

const params = new URL(Astro.url).searchParams;

const page = Math.max(1, parseInt(params.get("page") ?? "1", 10));
const pageSize = 9;

const q   = (params.get("q")   ?? "").trim();
const cat = (params.get("cat") ?? "").trim();
const hasQuery = !!q;
const hasCat   = !!cat;

let articles   = [];
let pageCount  = 1;
let total      = 0;
let featured   = null;
let categories = [];

const toAbs = (maybeUrl) => {
  if (!maybeUrl) return null;
  if (/^https?:\/\//i.test(maybeUrl)) return maybeUrl;
  try { return new URL(maybeUrl, STRAPI_URL).toString(); }
  catch { return null; }
};

const pickMediaUrl = (media) => {
  const m =
    media?.data?.attributes ??
    media?.data ??
    media?.attributes ??
    media ??
    null;
  const rel =
    m?.formats?.large?.url ??
    m?.formats?.medium?.url ??
    m?.formats?.small?.url ??
    m?.url ??
    null;
  return rel ? toAbs(rel) : null;
};

try {
  // ─────────────────────────────────────────────────────────────────────────
  // IMPORTANTE: construir la QS con strings literales.
  // URLSearchParams codifica los corchetes → %5B%5D → Strapi los ignora.
  // ─────────────────────────────────────────────────────────────────────────
  const parts = [
    `pagination[page]=${page}`,
    `pagination[pageSize]=${pageSize}`,
    `sort=publishedAt:desc`,
    `populate[0]=cover`,
    `populate[1]=author.avatar`,
    `populate[2]=category`,
    `populate[3]=blocks`,
  ];

  if (q)   parts.push(`filters[title][$containsi]=${encodeURIComponent(q)}`);
  if (cat) parts.push(`filters[category][slug][$eq]=${encodeURIComponent(cat)}`);

  const qs = parts.join("&");

  const populateSimple = "populate[0]=cover&populate[1]=author.avatar&populate[2]=category&populate[3]=blocks";

  const [mainRes, featuredRes, catsRes] = await Promise.all([
    fetch(`${STRAPI_URL}/api/articles?${qs}`),
    page === 1 && !q && !cat
      ? fetch(`${STRAPI_URL}/api/articles?${populateSimple}&pagination[limit]=1&sort=publishedAt:desc&filters[featured][$eq]=true`)
      : Promise.resolve(null),
    fetch(`${STRAPI_URL}/api/categories?pagination[pageSize]=100&sort=name:asc`),
  ]);

  const mainData = await mainRes.json();
  articles  = mainData?.data ?? [];
  pageCount = mainData?.meta?.pagination?.pageCount ?? 1;
  total     = mainData?.meta?.pagination?.total ?? 0;

  const catsData = await catsRes.json();
  categories = (catsData?.data ?? []).map((c) => c?.attributes ?? c);

  if (featuredRes) {
    const featuredData = await featuredRes.json();
    const raw = featuredData?.data?.[0];
    if (raw) featured = raw.attributes ?? raw;
  }
} catch (e) {
  articles = []; pageCount = 1; total = 0; featured = null; categories = [];
}

const featuredSlug  = featured?.slug ?? null;
const gridArticles  =
  page === 1 && featuredSlug && !hasQuery && !hasCat
    ? articles.filter((it) => (it.attributes?.slug ?? it.slug) !== featuredSlug)
    : articles;

const clearUrl  = "/blog";
const buildUrl  = (nextPage) => {
  const u = new URL("/blog", "https://dummy.local");
  if (q)   u.searchParams.set("q", q);
  if (cat) u.searchParams.set("cat", cat);
  if (nextPage && nextPage > 1) u.searchParams.set("page", String(nextPage));
  return u.pathname + (u.search ? u.search : "");
};

const activeCategoryName =
  cat ? (categories.find((c) => c.slug === cat)?.name ?? null) : null;
---

<BaseLayout
  title="Blog — ZetaGadget"
  description="Artículos, guías y noticias sobre tecnología y gadgets en ZetaGadget."
>
  <main class="container-page py-10">

    <!-- Header -->
    <div
      class="mb-8 rounded-3xl p-6 sm:p-8"
      style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);"
    >
      <div class="flex flex-col gap-2 max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-widest" style="color:#1e88e5;">Blog</p>

        <div class="flex flex-wrap items-end justify-between gap-3">
          <h1 class="text-3xl sm:text-4xl font-extrabold" style="color:#e5e5e5;">
            Artículos &amp; Guías
          </h1>
          {total > 0 && (
            <span
              class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold"
              style="background: rgba(30,136,229,0.10); color: #3aa0ff; border: 1px solid rgba(30,136,229,0.22);"
            >
              <span data-blog-count>{total}</span>&nbsp;artículo{total !== 1 ? "s" : ""}
            </span>
          )}
        </div>

        <p class="text-sm sm:text-base leading-relaxed" style="color: rgba(229,229,229,0.55);">
          Noticias, análisis y consejos sobre el mundo tech. Actualizado regularmente.
        </p>

        {pageCount > 1 && (
          <p class="text-xs mt-1" style="color: rgba(229,229,229,0.35);">
            Página {page} de {pageCount}
          </p>
        )}
      </div>
    </div>

    <!-- Toolbar: búsqueda + categoría -->
    <form
      class="mb-10 rounded-3xl p-4 sm:p-5 flex flex-col lg:flex-row gap-3 lg:items-end"
      style="background:#151a22; border: 1px solid rgba(255,255,255,0.08);"
      method="get"
      action="/blog"
    >
      <!-- Búsqueda -->
      <div class="flex-1 flex items-center gap-3">
        <div
          class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0"
          style="background: rgba(30,136,229,0.10); border: 1px solid rgba(30,136,229,0.20);"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="5" stroke="rgba(58,160,255,0.9)" stroke-width="1.5"/>
            <path d="M12 12l4 4" stroke="rgba(58,160,255,0.9)" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="w-full">
          <label class="block text-xs font-semibold mb-1" style="color: rgba(229,229,229,0.65);">
            Buscar artículos
          </label>
          <input
            name="q"
            data-blog-q
            value={q}
            placeholder=""
            class="w-full rounded-xl px-4 py-3 text-sm outline-none"
            style="background:#0f1115; border: 1px solid rgba(255,255,255,0.12); color:#e5e5e5;"
          />
        </div>
      </div>

      <!-- Categoría -->
      <div class="w-full lg:w-72">
        <label class="block text-xs font-semibold mb-1" style="color: rgba(229,229,229,0.65);">
          Categoría
        </label>
        <select
          name="cat"
          data-blog-cat
          class="w-full rounded-xl px-4 py-3 text-sm outline-none"
          style="background:#0f1115; border: 1px solid rgba(255,255,255,0.12); color:#e5e5e5;"
        >
          <option value="">Todas</option>
          {categories.map((c) => (
            <option value={c.slug} selected={cat === c.slug}>{c.name}</option>
          ))}
        </select>
      </div>

      <!-- Botones -->
      
    </form>

    <!-- Chips filtros activos -->
    {(hasQuery || hasCat) && (
      <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
        <div class="flex flex-wrap items-center gap-2">
          {hasQuery && (
            <span
              class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold"
              style="background: rgba(30,136,229,0.10); color: #3aa0ff; border: 1px solid rgba(30,136,229,0.20);"
            >
              "{q}"
            </span>
          )}
          {hasCat && activeCategoryName && (
            <span
              class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold"
              style="background: rgba(30,136,229,0.10); color: #3aa0ff; border: 1px solid rgba(30,136,229,0.20);"
            >
              {activeCategoryName}
            </span>
          )}
        </div>
        <a
          href={clearUrl}
          class="inline-flex items-center gap-1.5 text-xs font-semibold"
          style="color: rgba(229,229,229,0.45);"
        >
          Quitar filtros
        </a>
      </div>
    )}

    <!-- Grid artículos -->
    {gridArticles.length > 0 ? (
      <div data-blog-grid class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {gridArticles.map((item: any) => {
          const a = item?.attributes ?? item;
          const author =
            a.author?.data?.attributes ??
            a.author?.data ??
            a.author ??
            null;
          const coverAbs = pickMediaUrl(a.cover);
          const readingTime = getReadingTimeMinutes({ content: a.content, blocks: a.blocks });

          return (
            <article
              data-blog-card
              data-title={(a.title ?? "").toLowerCase()}
              data-cat={a.category?.data?.attributes?.slug ?? a.category?.slug ?? ""}
              data-reading={readingTime}
              class="contents"
            >
              <ArticleCard
                article={{
                  title: a.title,
                  slug: a.slug,
                  description: a.description ?? a.excerpt,
                  coverUrl: coverAbs,
                  authorName: author?.name ?? a.authorName ?? null,
                  publishedAt: a.publishedAt,
                  readingTime,
                }}
              />
            </article>
          );
        })}
      </div>
    ) : (
      <div
        data-blog-empty
        class="py-24 text-center rounded-3xl"
        style="background:#151a22; border: 1px solid rgba(255,255,255,0.07);"
      >
        <p class="text-lg font-semibold mb-2" style="color:#e5e5e5;">Sin resultados</p>
        <p class="text-sm mb-6" style="color: rgba(229,229,229,0.45);">
          Prueba con otro término o cambia la categoría.
        </p>
        <a href="/blog" class="px-5 py-2.5 rounded-xl text-sm font-semibold" style="background:#1e88e5; color:#fff;">
          Ver todos
        </a>
      </div>
    )}

    {pageCount > 1 && (
      <div class="mt-12 flex justify-center">
        <Pagination pagination={{ page, pageCount }} buildUrl={buildUrl} />
      </div>
    )}

  </main>
  <script src="/scripts/blog-filter.js" is:inline></script>
</BaseLayout>